# Copy this file to .env.local and fill in your secrets.
# .env.local is gitignored and must never be committed.
# Values are read from the real environment first, then from .env.local.

# --- Data sources -----------------------------------------------------------------
# yfinance and Stooq need NO key (anonymous), so you can start with NOTHING set here.

# SEC EDGAR requires a descriptive User-Agent (name + email), not an API key. The SEC
# blocks requests without one. Set yours here; plutus.data.sources.sec_edgar reads it.
SEC_EDGAR_USER_AGENT=

# --- Paper / live trading (Alpaca) ------------------------------------------------
# Free paper-trading account at https://alpaca.markets. Use the PAPER keys + paper
# base URL until a live record holds up. NEVER commit live keys.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Network proxy (OPTIONAL) -------------------------------------------------------
# yfinance / SEC EDGAR are foreign hosts; if your network needs a local proxy
# to reach them, uncomment and point at it. These are the standard names honored by
# requests/yfinance/urllib; plutus.config exports them to the process environment at
# import (a value already set in the real environment always wins).
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
# NO_PROXY=localhost,127.0.0.1
